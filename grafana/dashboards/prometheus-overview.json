          "refId": "A"
        }
      ],
      "title": "Target Up",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "description": "How many time series are in memory (approx.)",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PROM" },
          "expr": "prometheus_tsdb_head_series",
          "legendFormat": "head series",
          "refId": "A"
        }
      ],
      "title": "Head Series",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "description": "Prometheus rule evaluation duration (seconds)",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PROM" },
          "expr": "rate(prometheus_rule_evaluation_duration_seconds_sum[5m]) / rate(prometheus_rule_evaluation_duration_seconds_count[5m])",
          "legendFormat": "avg eval duration",
          "refId": "A"
        }
      ],
      "title": "Rule Eval Avg Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "description": "Query rate inside Prometheus",
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
